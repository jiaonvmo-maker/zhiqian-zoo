# Base path for production deployment
# Leave empty for root deployment, or set to '/your-project-name/' for subdirectory
VITE_BASE_PATH=/

# API Configuration (if needed in the future)
# VITE_API_URL=https://api.example.com

# Debug mode
VITE_ENABLE_DEBUG=false

# Analytics — 默认已启用 webhook 收集（见 docs/analytics-setup.md）
VITE_ANALYTICS_ENDPOINT=https://webhook.site/16afb4a2-3919-4805-bb4f-5928d9dc2585

# 可选 PostHog
# VITE_POSTHOG_KEY=phc_xxxxxxxx
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# VITE_ANALYTICS_DEBUG=true
